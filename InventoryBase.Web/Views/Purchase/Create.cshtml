@{ ViewData["Title"] = "New purchase"; ViewData["NavId"] = "purchases";
   var suppliers = (IEnumerable<InventoryBase.Core.Entities.Supplier>)ViewBag.Suppliers; }
@section Styles {
<style>
.line-table{width:100%;border-collapse:collapse;font-size:13px}
.line-table th{text-align:left;font-size:11.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;padding:8px 10px;background:var(--surface-2);border-bottom:1px solid var(--border)}
.line-table td{padding:6px 8px;border-bottom:1px solid var(--border);vertical-align:middle}
.line-table tr:last-child td{border-bottom:none}
</style>
}
<div class="content">
  <div class="page-head">
    <div><h1 class="page-title">New purchase</h1></div>
    <div class="page-actions"><a class="btn" href="@Url.Action("Index","Purchase")">Cancel</a></div>
  </div>
  <form method="post" asp-controller="Purchase" asp-action="Create">
    @Html.AntiForgeryToken()
    <div class="split">
      <div class="col gap-16">
        <div class="card">
          <div class="card-head"><div class="card-title">Purchase details</div></div>
          <div class="card-body">
            <div class="form-grid">

                            <input class="input mono" name="InvoiceNo" id="invoiceNo" readonly
                                   placeholder="Generating…" style="background:var(--surface-2);cursor:default;color:var(--muted)" />

                @* <div class="field"><label class="label">Invoice no.</label><input class="input mono" name="InvoiceNo" placeholder="Auto-generated if blank"/></div> *@
              <div class="field"><label class="label">Date <span class="req">*</span></label><input class="input" name="PurchaseDate" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" required/></div>
              <div class="field span-2">
                <label class="label" style="display:flex;align-items:center;justify-content:space-between">
                  <span>Supplier <span class="req">*</span></span>
                  <button type="button" class="btn btn-sm" id="btnNewSupplier" style="padding:2px 8px;font-size:11.5px">+ New supplier</button>
                </label>
                <select class="select s2-sup" name="SupplierId" required>
                  <option value="">— Select supplier —</option>
                  @foreach (var s in suppliers) {
                    var supTxt = string.IsNullOrEmpty(s.Phone) ? s.Name : $"{s.Name} · {s.Phone}";
                    <option value="@s.Id" data-phone="@s.Phone">@supTxt</option>
                  }
                </select>
              </div>
              <div class="field span-2"><label class="label">Note</label><textarea class="textarea" name="Note" style="min-height:60px"></textarea></div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-head">
            <div class="card-title">Line items</div>
            <button type="button" class="btn btn-sm" onclick="addLine()">+ Add product</button>
          </div>
          <div class="card-body" style="padding:0">
            <table class="line-table">
              <thead><tr><th style="width:40%">Product</th><th>Unit</th><th>Qty</th><th>Unit cost (৳)</th><th>Subtotal</th><th style="width:40px"></th></tr></thead>
              <tbody id="lineBody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="col gap-12">
        <div class="card"><div class="card-head"><div class="card-title">Summary</div></div><div class="card-body">
          <div style="font-size:13px;display:flex;flex-direction:column;gap:8px">
            <div style="display:flex;justify-content:space-between"><span class="muted">Lines</span><span id="lineCount">0</span></div>
            <div style="display:flex;justify-content:space-between;border-top:1px solid var(--border);padding-top:10px;font-weight:600;font-size:15px"><span>Total</span><span id="grandTotal" class="mono">৳ 0.00</span></div>
          </div>
        </div></div>
        <button type="submit" class="btn btn-primary">Save purchase</button>
      </div>
    </div>
  </form>
</div>

<dialog id="supplierModal" style="border:1px solid var(--border);border-radius:var(--radius);padding:0;background:var(--surface);color:var(--text);min-width:360px;max-width:440px;width:100%">
  <form id="supplierForm" method="dialog">
    <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
      <div class="card-title">New supplier</div>
      <button type="button" id="closeSupplierModal" class="btn btn-ghost btn-icon btn-sm">✕</button>
    </div>
    <div style="padding:18px;display:flex;flex-direction:column;gap:12px">
      <div class="field"><label class="label">Name <span class="req">*</span></label><input class="input" id="supName" required/></div>
      <div class="field"><label class="label">Contact person</label><input class="input" id="supContact"/></div>
      <div class="field"><label class="label">Phone</label><input class="input" id="supPhone"/></div>
      <div class="field"><label class="label">Email</label><input class="input" id="supEmail" type="email"/></div>
      <div class="field"><label class="label">Address</label><textarea class="textarea" id="supAddress" style="min-height:60px"></textarea></div>
    </div>
    <div style="padding:12px 18px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px">
      <button type="button" id="cancelSupplier" class="btn">Cancel</button>
      <button type="submit" class="btn btn-primary">Add supplier</button>
    </div>
  </form>
</dialog>

@section Scripts {
<script>
let lineIdx = 0;

        // Fetch and lock the invoice number on page load
        fetch('/Purchase/NextInvoiceNo')
          .then(r => r.json())
          .then(d => {
            const el = document.getElementById('invoiceNo');
            el.value = d.invoiceNo;
            el.style.color = '';   // restore normal text color
          });

function addLine() {
  const idx = lineIdx++;
  const tr  = document.createElement('tr');
  tr.id = `line-${idx}`;
  tr.innerHTML = `
    <td>
      <select class="select s2-prod" name="productIds" style="width:100%" data-idx="${idx}">
        <option value="">— Search product —</option>
      </select>
    </td>
    <td><span class="muted" id="unit-${idx}">—</span></td>
    <td><input class="input mono" name="quantities" type="number" min="1" step="1" value="1" style="width:80px" onchange="recalc(${idx})"/></td>
    <td><input class="input mono" name="unitCosts"  type="number" min="0"     step="1"  value="0" id="cost-${idx}" style="width:100px" onchange="recalc(${idx})"/></td>
    <td class="mono" id="sub-${idx}">৳ 0</td>
    <td><button type="button" onclick="removeLine(${idx})" class="btn btn-ghost btn-icon btn-sm btn-danger">✕</button></td>
  `;
  document.getElementById('lineBody').appendChild(tr);

  $(`select[data-idx="${idx}"]`).select2({
    placeholder: '— Search product —',
    ajax: {
      url: '/Purchase/ProductSearch',
      dataType: 'json',
      delay: 200,
      data: params => ({ q: params.term }),
      processResults: data => ({ results: data })
    },
    width: '100%'
  }).on('select2:select', function(e) {
    const d = e.params.data;
    document.getElementById(`unit-${idx}`).textContent = d.unit || '—';
    document.getElementById(`cost-${idx}`).value = d.cost;
    recalc(idx);
  });

  updateSummary();
}

function removeLine(idx) {
  document.getElementById(`line-${idx}`)?.remove();
  updateSummary();
}

function recalc(idx) {
  const row  = document.getElementById(`line-${idx}`);
  if (!row) return;
  const qty  = parseFloat(row.querySelector('[name=quantities]').value) || 0;
  const cost = parseFloat(row.querySelector('[name=unitCosts]').value)  || 0;
  const sub  = qty * cost;
  document.getElementById(`sub-${idx}`).textContent = '৳ ' + sub.toLocaleString('en-BD', {minimumFractionDigits:2});
  updateSummary();
}

function updateSummary() {
  const rows   = document.querySelectorAll('#lineBody tr');
  let total    = 0;
  rows.forEach(row => {
    const qty  = parseFloat(row.querySelector('[name=quantities]')?.value) || 0;
    const cost = parseFloat(row.querySelector('[name=unitCosts]')?.value)  || 0;
    total += qty * cost;
  });
  document.getElementById('lineCount').textContent  = rows.length;
  document.getElementById('grandTotal').textContent = '৳ ' + total.toLocaleString('en-BD', {minimumFractionDigits:2});
}

$('.s2-sup').select2({
  placeholder: '— Select supplier —', width: '100%',
  templateResult: function(opt) {
    if (!opt.element) return opt.text;
    var phone = opt.element.dataset.phone;
    if (!phone) return $('<span>' + opt.element.text + '</span>');
    var name = opt.element.text.replace(' · ' + phone, '');
    return $('<span style="line-height:1.6"><span style="font-weight:500">' + name + '</span><br><span style="font-size:11px;color:var(--muted)">' + phone + '</span></span>');
  }
});

// ── Quick add supplier modal ──────────────────────────────────────────
const supplierModal = document.getElementById('supplierModal');
document.getElementById('btnNewSupplier').addEventListener('click', () => {
  document.getElementById('supplierForm').reset();
  supplierModal.showModal();
  document.getElementById('supName').focus();
});
document.getElementById('closeSupplierModal').addEventListener('click', () => supplierModal.close());
document.getElementById('cancelSupplier').addEventListener('click', () => supplierModal.close());
supplierModal.addEventListener('click', e => { if (e.target === supplierModal) supplierModal.close(); });

document.getElementById('supplierForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const name = document.getElementById('supName').value.trim();
  if (!name) { toastr.error('Name is required.'); return; }
  try {
    const d = await apiPost('/Purchase/QuickAddSupplier', {
      name,
      contactPerson: document.getElementById('supContact').value.trim(),
      phone:         document.getElementById('supPhone').value.trim(),
      email:         document.getElementById('supEmail').value.trim(),
      address:       document.getElementById('supAddress').value.trim()
    });
    if (!d.ok) { toastr.error(d.message || 'Failed to add supplier.'); return; }
    // Add the new supplier to the dropdown and select it
    const opt = new Option(d.text, d.id, true, true);
    opt.dataset.phone = d.phone || '';
    $('.s2-sup').append(opt).trigger('change');
    supplierModal.close();
    toastr.success('Supplier added.');
  } catch (err) { toastr.error('Request failed.'); console.error(err); }
});

addLine(); // start with one empty line
</script>
}
