@{ ViewData["Title"] = "Purchases"; ViewData["NavId"] = "purchases"; }
<style>
  .date-range { display:flex; align-items:center; gap:6px; }
  .date-range label { font-size:12px; color:var(--text-2); white-space:nowrap; }
  .date-range input[type=date] {
    background:var(--surface-2); border:1px solid var(--border);
    border-radius:var(--radius-sm); padding:5px 8px;
    font-size:12.5px; color:var(--text); outline:none;
    cursor:pointer; height:32px;
  }
  .date-range input[type=date]:focus { border-color:var(--border-2); background:var(--surface); }
  .btn-clear {
    padding:5px 10px; font-size:12px; height:32px;
    background:var(--surface-2); border:1px solid var(--border);
    border-radius:var(--radius-sm); color:var(--text-2);
    cursor:pointer; white-space:nowrap;
  }
  .btn-clear:hover { border-color:var(--border-2); color:var(--text); }
</style>
<div class="content">
  <div class="page-head">
    <div><h1 class="page-title">Purchases</h1><div class="page-sub">Purchase orders and stock-in history.</div></div>
    <div class="page-actions"><a class="btn btn-primary" href="@Url.Action("Create","Purchase")">+ New purchase</a></div>
  </div>
  <div class="table-wrap">
    <div class="table-toolbar">
      <div class="search-box"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg><input id="search" placeholder="Search invoice or supplier…"/></div>
      <div class="date-range">
        <label for="dateFrom">From</label>
        <input type="date" id="dateFrom" />
        <label for="dateTo">To</label>
        <input type="date" id="dateTo" />
        <button class="btn-clear" id="btnClearDates" title="Clear date filter">✕ Clear</button>
      </div>
      <div class="spacer"></div><span class="xs muted" id="rowCount"></span>
    </div>
    <div id="poTable"></div>
  </div>
</div>
@section Scripts {
<script>
const _pad = n => String(n).padStart(2, '0');
const _fmt = d => `${d.getFullYear()}-${_pad(d.getMonth()+1)}-${_pad(d.getDate())}`;
const _today = new Date();
const _firstOfMonth = new Date(_today.getFullYear(), _today.getMonth(), 1);
document.getElementById('dateFrom').value = _fmt(_firstOfMonth);
document.getElementById('dateTo').value   = _fmt(_today);

let filters = { search: '', dateFrom: _fmt(_firstOfMonth), dateTo: _fmt(_today) };
const table = new Tabulator('#poTable', {
  ...window.tabulatorDefaults, ajaxURL: '/Purchase/Data', ajaxParams: () => ({ ...filters }),
  columns: [
    { title: 'Invoice',  field: 'invoiceNo',    width: 130, formatter: c => `<span class="mono bold">${c.getValue()}</span>` },
    { title: 'Supplier', field: 'supplier',     widthGrow: 2 },
    { title: 'Date',     field: 'purchaseDate', width: 130, formatter: c => `<span class="muted">${c.getValue()}</span>` },
    { title: 'Total (৳)',field: 'totalAmount',  width: 130, hozAlign: 'right', formatter: moneyFormatter },
    { title: 'Note',     field: 'note',         widthGrow: 2, formatter: c => `<span class="muted">${c.getValue()}</span>` },
    { title: '', field: 'hash', width: 200, hozAlign: 'right', headerSort: false,
      formatter: cell => {
        const h = cell.getValue();
        return `<div style="display:flex;gap:4px;justify-content:flex-end">
          <a href="/Purchase/Details/${h}" class="btn btn-ghost btn-sm">View</a>
          <a href="/Purchase/Edit/${h}" class="btn btn-ghost btn-sm">Edit</a>
          <button class="btn btn-ghost btn-sm btn-danger" onclick="deletePurchase('${h}',event)">Delete</button>
        </div>`;
      }
    }
  ]
});
table.on('dataProcessed', () => { document.getElementById('rowCount').textContent = table.getDataCount('active') + ' rows'; });

let deb;
document.getElementById('search').addEventListener('input', e => {
  clearTimeout(deb); deb = setTimeout(() => { filters.search = e.target.value; table.setPage(1); }, 350);
});
document.getElementById('dateFrom').addEventListener('change', e => { filters.dateFrom = e.target.value; table.setPage(1); });
document.getElementById('dateTo').addEventListener('change', e => { filters.dateTo = e.target.value; table.setPage(1); });
document.getElementById('btnClearDates').addEventListener('click', () => {
  document.getElementById('dateFrom').value = '';
  document.getElementById('dateTo').value = '';
  filters.dateFrom = ''; filters.dateTo = '';
  table.setPage(1);
});

async function deletePurchase(hash, event) {
  event.stopPropagation();
  if (!confirm('Delete this purchase? Stock movements will be reversed.')) return;
  try {
    const d = await apiPost('/Purchase/Delete', { id: hash });
    if (d.success) { toastr.success('Purchase deleted.'); table.replaceData(); }
    else toastr.error(d.message || 'Failed to delete.');
  } catch(e) { toastr.error('Request failed.'); console.error(e); }
}
</script>
}
