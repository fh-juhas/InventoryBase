@{ ViewData["Title"] = "Reports"; ViewData["NavId"] = "reports"; }
@section Styles {
<style>
.report-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:16px}
.pl-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px}
.pl-row:last-child{border-bottom:none}
.pl-row.total{border-top:2px solid var(--border);font-weight:600;font-size:15px;padding-top:12px;margin-top:4px}
@@media(max-width:1100px){.report-grid{grid-template-columns:1fr}}

/* detailed reports section */
.drpt-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
@@media(max-width:900px){.drpt-grid{grid-template-columns:1fr}}
.drpt-card{background:var(--surface-2);border:1px solid var(--border);border-radius:var(--radius);padding:16px}
.drpt-card-title{font-weight:600;font-size:13.5px;margin-bottom:4px}
.drpt-card-desc{font-size:12px;color:var(--text-2);margin-bottom:12px;line-height:1.6}
.drpt-controls{display:flex;flex-wrap:wrap;align-items:center;gap:6px}
.drpt-controls input[type=date]{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:5px 8px;font-size:12px;color:var(--text);outline:none;height:32px;cursor:pointer}
.drpt-controls input[type=date]:focus{border-color:var(--border-2)}
.drpt-controls .lbl{font-size:11.5px;color:var(--text-2);white-space:nowrap}
.drpt-controls select{height:32px;font-size:12.5px}
</style>
}
<div class="content">
  <div class="page-head">
    <div><h1 class="page-title">Reports</h1><div class="page-sub">Financial summaries and business insights.</div></div>
    <div class="page-actions">
      <select class="select s2-month" id="rMonth" style="width:130px">
        @{ var months = System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.MonthNames.Take(12).ToArray(); }
        @for (int m = 1; m <= 12; m++) {
          <option value="@m" selected="@(m==DateTime.Now.Month)">@months[m-1]</option>
        }
      </select>
      <select class="select s2-year" id="rYear" style="width:90px">
        @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--) {
          <option value="@y" selected="@(y==DateTime.Now.Year)">@y</option>
        }
      </select>
      <button class="btn btn-primary" onclick="loadReports()">Load</button>
    </div>
  </div>

  <!-- P&L + Top Products -->
  <div class="report-grid">
    <div class="card">
      <div class="card-head"><div class="card-title">Profit &amp; Loss</div><span class="xs muted" id="plPeriod"></span></div>
      <div class="card-body" id="plBody">
        <div style="color:var(--muted);font-size:13px">Click Load to generate the report.</div>
      </div>
    </div>
    <div class="card">
      <div class="card-head"><div class="card-title">Top selling products</div><span class="xs muted" id="topPeriod"></span></div>
      <div class="card-body" style="padding:6px 16px 12px" id="topBody">
        <div style="color:var(--muted);font-size:13px">Click Load to generate the report.</div>
      </div>
    </div>
  </div>

  <!-- 12-month sales trend -->
  <div class="card" style="margin-bottom:16px">
    <div class="card-head"><div class="card-title">Monthly sales trend</div><span class="xs muted">Last 12 months</span></div>
    <div class="card-body"><canvas id="trendChart" style="max-height:240px"></canvas></div>
  </div>

  <!-- Detailed print reports -->
  <div class="card" style="margin-bottom:16px">
    <div class="card-head">
      <div class="card-title">Detailed Reports</div>
      <span class="xs muted">Print-ready — opens in a new tab</span>
    </div>
    <div class="card-body">
      <div class="drpt-grid">

        <!-- P&L Annual -->
        <div class="drpt-card">
          <div class="drpt-card-title">Profit &amp; Loss (Annual)</div>
          <div class="drpt-card-desc">Month-wise breakdown of sales revenue vs purchases, confirmed expenses, and employee salaries for a selected year.</div>
          <div class="drpt-controls">
            <span class="lbl">Year</span>
            <select class="select" id="plDetailYear" style="width:100px">
              @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 4; y--) {
                <option value="@y" selected="@(y == DateTime.Now.Year)">@y</option>
              }
            </select>
            <button class="btn btn-primary btn-sm" onclick="openPlDetail()">Open Report</button>
          </div>
        </div>

        <!-- Product Report -->
        <div class="drpt-card">
          <div class="drpt-card-title">Product Inventory Report</div>
          <div class="drpt-card-desc">Stock in/out quantity and value per product within a date range, plus current total stock level for every active product.</div>
          <div class="drpt-controls">
            <span class="lbl">From</span>
            <input type="date" id="prodFrom" />
            <span class="lbl">To</span>
            <input type="date" id="prodTo" />
            <button class="btn btn-primary btn-sm" onclick="openProductReport()">Open Report</button>
          </div>
        </div>

        <!-- Customer Report -->
        <div class="drpt-card">
          <div class="drpt-card-title">Customer Revenue Report</div>
          <div class="drpt-card-desc">Top customers ranked by revenue contribution with percentage share and visual bar for the selected date range.</div>
          <div class="drpt-controls">
            <span class="lbl">From</span>
            <input type="date" id="custFrom" />
            <span class="lbl">To</span>
            <input type="date" id="custTo" />
            <button class="btn btn-primary btn-sm" onclick="openCustomerReport()">Open Report</button>
          </div>
        </div>

        <!-- Supplier Report -->
        <div class="drpt-card">
          <div class="drpt-card-title">Supplier Purchase Report</div>
          <div class="drpt-card-desc">Top suppliers ranked by purchase volume with concentration percentage, useful for identifying supply chain dependency.</div>
          <div class="drpt-controls">
            <span class="lbl">From</span>
            <input type="date" id="suppFrom" />
            <span class="lbl">To</span>
            <input type="date" id="suppTo" />
            <button class="btn btn-primary btn-sm" onclick="openSupplierReport()">Open Report</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
$('.s2-month').select2({ minimumResultsForSearch: Infinity, width: '130px' });
$('.s2-year').select2({ minimumResultsForSearch: Infinity, width: '90px' });

const fmt = v => '৳ ' + parseFloat(v||0).toLocaleString('en-BD', { minimumFractionDigits: 2 });

async function loadReports() {
  const month = document.getElementById('rMonth').value;
  const year  = document.getElementById('rYear').value;
  const period = `${document.getElementById('rMonth').options[month-1].text} ${year}`;

  document.getElementById('plPeriod').textContent  = period;
  document.getElementById('topPeriod').textContent = period;

  // P&L
  const pl = await fetch(`/Report/ProfitLoss?month=${month}&year=${year}`).then(r=>r.json());
  document.getElementById('plBody').innerHTML = `
    <div class="pl-row"><span class="muted">Revenue</span><span class="mono">${fmt(pl.revenue)}</span></div>
    <div class="pl-row"><span class="muted">Cost of goods sold</span><span class="mono" style="color:var(--danger)">− ${fmt(pl.cogs)}</span></div>
    <div class="pl-row"><span>Gross profit</span><span class="mono bold">${fmt(pl.grossProfit)}</span></div>
    <div class="pl-row"><span class="muted">Confirmed expenses</span><span class="mono" style="color:var(--danger)">− ${fmt(pl.expenses)}</span></div>
    <div class="pl-row total"><span>Net profit</span><span class="mono" style="color:${pl.netProfit>=0?'var(--success)':'var(--danger)'}">${fmt(pl.netProfit)}</span></div>
  `;

  // Top products
  const tops = await fetch(`/Report/TopProducts?month=${month}&year=${year}`).then(r=>r.json());
  if (!tops.length) {
    document.getElementById('topBody').innerHTML = '<div class="muted xs">No sales this period.</div>';
  } else {
    document.getElementById('topBody').innerHTML = tops.map((p, i) => `
      <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border)">
        <div style="display:flex;align-items:center;gap:10px">
          <span style="width:20px;height:20px;border-radius:50%;background:${i===0?'var(--text)':'var(--surface-2)'};color:${i===0?'var(--surface)':'var(--text-2)'};display:inline-grid;place-items:center;font-size:11px;font-weight:600">${i+1}</span>
          <div><div class="bold">${p.name}</div><div class="xs muted mono">${p.sku}</div></div>
        </div>
        <div style="text-align:right"><div class="mono bold">${fmt(p.revenue)}</div><div class="xs muted">${parseFloat(p.qtySold).toLocaleString('en-BD')} sold</div></div>
      </div>
    `).join('');
  }
}

// ── Detailed reports ───────────────────────────────────────────────────
(function() {
  const _pad  = n => String(n).padStart(2, '0');
  const _fmt  = d => `${d.getFullYear()}-${_pad(d.getMonth()+1)}-${_pad(d.getDate())}`;
  const _now  = new Date();
  const _fom  = new Date(_now.getFullYear(), _now.getMonth(), 1);
  const today = _fmt(_now);
  const fom   = _fmt(_fom);
  ['prodFrom','custFrom','suppFrom'].forEach(id => document.getElementById(id).value = fom);
  ['prodTo','custTo','suppTo'].forEach(id => document.getElementById(id).value = today);
})();

window.openPlDetail = function() {
  const y = document.getElementById('plDetailYear').value;
  window.open(`/Report/ProfitLossDetail?year=${y}`, '_blank');
};
window.openProductReport = function() {
  const f = encodeURIComponent(document.getElementById('prodFrom').value);
  const t = encodeURIComponent(document.getElementById('prodTo').value);
  window.open(`/Report/ProductReport?dateFrom=${f}&dateTo=${t}`, '_blank');
};
window.openCustomerReport = function() {
  const f = encodeURIComponent(document.getElementById('custFrom').value);
  const t = encodeURIComponent(document.getElementById('custTo').value);
  window.open(`/Report/CustomerReport?dateFrom=${f}&dateTo=${t}`, '_blank');
};
window.openSupplierReport = function() {
  const f = encodeURIComponent(document.getElementById('suppFrom').value);
  const t = encodeURIComponent(document.getElementById('suppTo').value);
  window.open(`/Report/SupplierReport?dateFrom=${f}&dateTo=${t}`, '_blank');
};

// 12-month trend chart
(async function() {
  const d = await fetch('/Report/MonthlySales').then(r=>r.json());
  new Chart(document.getElementById('trendChart').getContext('2d'), {
    type: 'line',
    data: {
      labels: d.labels,
      datasets: [{
        label: 'Sales',
        data: d.sales,
        borderColor: '#1c1917',
        backgroundColor: 'rgba(28,25,23,.06)',
        borderWidth: 2,
        pointRadius: 3,
        fill: true,
        tension: 0.3
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: ctx => ' ৳ ' + parseFloat(ctx.raw).toLocaleString('en-BD', {minimumFractionDigits:0}) } }
      },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#a8a29e' } },
        y: { grid: { color: '#e7e5e4' }, ticks: { font: { size: 11 }, color: '#a8a29e', callback: v => '৳'+(v>=1000?(v/1000).toFixed(0)+'k':v) } }
      }
    }
  });
})();
</script>
}
