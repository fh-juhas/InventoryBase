@using Microsoft.AspNetCore.Identity
@using InventoryBase.Core.Interfaces.Services
@inject SignInManager<InventoryBase.Core.Entities.ApplicationUser> SignInMgr
@inject UserManager<InventoryBase.Core.Entities.ApplicationUser> UserMgr
@inject ICompanyService CompanySvc
@{
    var current = (string)(ViewData["NavId"] ?? "");
    string nav(string id) => id == current ? "active" : "";
    var userObj = await UserMgr.GetUserAsync(User);
    var initials = userObj?.FullName is { Length: > 0 } fn
        ? string.Concat(fn.Split(' ').Where(w => w.Length > 0).Take(2).Select(w => w[0].ToString().ToUpper()))
        : "?";
    var displayName = userObj?.FullName ?? User.Identity?.Name ?? "User";
    var isAdmin = User.IsInRole("Admin");

    // Load company settings for sidebar branding
    var company = await CompanySvc.GetAsync();
    var companyName = !string.IsNullOrWhiteSpace(company.CompanyName) ? company.CompanyName : "InventoryBase";
    var companyLogo = company.LogoPath;
    var brandLetter = companyName.Length > 0 ? companyName[0].ToString().ToUpper() : "I";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · @companyName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@@400;500;600;700&family=Geist+Mono:wght@@400;500&display=swap" rel="stylesheet" />
    <!-- Tabulator -->
    <link href="https://unpkg.com/tabulator-tables@6.2.1/dist/css/tabulator_simple.min.css" rel="stylesheet" />
    <!-- Toastr -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <!-- Select2 -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        /* ── Design tokens ─────────────────────────── */
        :root{
          --bg:#fafaf8;--surface:#fff;--surface-2:#f5f5f3;
          --text:#1c1917;--text-2:#57534e;--muted:#a8a29e;
          --border:#e7e5e4;--border-2:#d6d3d1;
          --accent:oklch(.55 .10 55);--accent-soft:oklch(.96 .02 70);
          --success:oklch(.55 .10 145);--success-soft:oklch(.96 .03 145);
          --danger:oklch(.55 .15 25);--danger-soft:oklch(.96 .03 25);
          --warning:oklch(.65 .13 75);--warning-soft:oklch(.96 .05 80);
          --radius:6px;--radius-sm:4px;--sidebar-w:232px;
        }
        *{box-sizing:border-box}
        html,body{margin:0;padding:0;background:var(--bg);color:var(--text);
          font-family:"Geist",ui-sans-serif,system-ui,sans-serif;font-size:14px;
          line-height:1.45;-webkit-font-smoothing:antialiased}
        button{font:inherit;color:inherit}
        input,select,textarea{font:inherit;color:inherit}
        a{color:inherit;text-decoration:none}

        /* ── Layout ────────────────────────────────── */
        .app{display:grid;grid-template-columns:var(--sidebar-w) 1fr;min-height:100vh}
        .sidebar{border-right:1px solid var(--border);background:var(--surface);
          padding:18px 12px;display:flex;flex-direction:column;gap:4px;
          position:sticky;top:0;height:100vh;overflow-y:auto}
        .sidebar-brand{display:flex;align-items:center;gap:10px;padding:4px 8px 18px;
          border-bottom:1px solid var(--border);margin-bottom:10px}
        .brand-mark{width:28px;height:28px;border-radius:6px;background:var(--text);
          color:var(--surface);display:grid;place-items:center;font-weight:600;font-size:13px;flex-shrink:0;overflow:hidden}
        .brand-mark img{width:100%;height:100%;object-fit:cover}
        .brand-name{font-weight:600;font-size:14px;letter-spacing:-.01em}
        .brand-sub{font-size:11px;color:var(--muted);letter-spacing:.02em;text-transform:uppercase}
        .sidebar-section{font-size:10px;font-weight:600;color:var(--muted);
          letter-spacing:.08em;text-transform:uppercase;padding:14px 10px 6px}
        .nav-item{display:flex;align-items:center;gap:10px;padding:7px 10px;
          border-radius:var(--radius-sm);color:var(--text-2);font-size:13.5px;
          border:none;background:none;width:100%;text-align:left;text-decoration:none;cursor:pointer}
        .nav-item:hover{background:var(--surface-2);color:var(--text)}
        .nav-item.active{background:var(--surface-2);color:var(--text);font-weight:500}
        .nav-item .icon{width:16px;height:16px;flex-shrink:0;opacity:.7}
        .nav-item.active .icon{opacity:1}
        .sidebar-footer{margin-top:auto;padding:10px 8px;
          border-top:1px solid var(--border);display:flex;align-items:center;gap:10px}
        .avatar{width:28px;height:28px;border-radius:50%;background:var(--accent-soft);
          color:var(--accent);display:grid;place-items:center;font-size:11px;font-weight:600;flex-shrink:0}
        .user-name{font-size:13px;font-weight:500}.user-role{font-size:11px;color:var(--muted)}
        .main{min-width:0;display:flex;flex-direction:column}
        .topbar{height:56px;border-bottom:1px solid var(--border);display:flex;
          align-items:center;gap:16px;padding:0 28px;background:var(--surface);
          position:sticky;top:0;z-index:10}
        .topbar-title{font-size:14px;font-weight:500}
        .topbar-sub{color:var(--muted);font-size:13px}
        .topbar-spacer{flex:1}
        .content{padding:28px;flex:1;min-width:0}
        .page-head{display:flex;align-items:flex-end;justify-content:space-between;
          margin-bottom:22px;gap:16px;flex-wrap:wrap}
        .page-title{font-size:22px;font-weight:600;letter-spacing:-.02em;margin:0}
        .page-sub{color:var(--muted);font-size:13.5px;margin-top:2px}
        .page-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}

        /* ── Buttons ───────────────────────────────── */
        .btn{display:inline-flex;align-items:center;gap:6px;padding:7px 12px;
          border-radius:var(--radius-sm);border:1px solid var(--border-2);
          background:var(--surface);color:var(--text);font-size:13px;
          font-weight:500;cursor:pointer;text-decoration:none;white-space:nowrap}
        .btn:hover{background:var(--surface-2)}
        .btn-primary{background:var(--text);color:var(--surface);border-color:var(--text)}
        .btn-primary:hover{background:var(--text-2);border-color:var(--text-2)}
        .btn-ghost{border-color:transparent;background:transparent}
        .btn-ghost:hover{background:var(--surface-2)}
        .btn-icon{padding:7px}
        .btn-sm{padding:4px 8px;font-size:12px}
        .btn-danger{color:var(--danger)}
        .btn-danger:hover{background:var(--danger-soft);border-color:transparent}

        /* ── Cards ─────────────────────────────────── */
        .card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius)}
        .card-head{padding:14px 16px;border-bottom:1px solid var(--border);
          display:flex;align-items:center;justify-content:space-between}
        .card-title{font-size:13px;font-weight:600}
        .card-body{padding:16px}

        /* ── Stats ─────────────────────────────────── */
        .stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}
        .stat{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px}
        .stat-label{font-size:12px;color:var(--muted);font-weight:500}
        .stat-value{font-size:24px;font-weight:600;letter-spacing:-.02em;margin-top:6px;font-feature-settings:"tnum"}
        .stat-sub{font-size:11.5px;color:var(--muted);margin-top:6px}

        /* ── Table toolbar ──────────────────────────── */
        .table-wrap{background:var(--surface);border:1px solid var(--border);
          border-radius:var(--radius);overflow:hidden}
        .table-toolbar{display:flex;align-items:center;gap:8px;
          padding:10px 12px;border-bottom:1px solid var(--border);flex-wrap:wrap}
        .search-box{display:flex;align-items:center;gap:8px;background:var(--surface-2);
          border:1px solid transparent;border-radius:var(--radius-sm);padding:6px 10px;width:240px}
        .search-box input{border:none;background:none;outline:none;font-size:13px;
          flex:1;color:var(--text)}
        .search-box:focus-within{border-color:var(--border-2);background:var(--surface)}
        .spacer{flex:1}

        /* ── Badges ────────────────────────────────── */
        .badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;
          border-radius:100px;font-size:11.5px;font-weight:500;
          background:var(--surface-2);color:var(--text-2);border:1px solid var(--border);white-space:nowrap}
        .badge.success{background:var(--success-soft);color:var(--success);border-color:transparent}
        .badge.danger{background:var(--danger-soft);color:var(--danger);border-color:transparent}
        .badge.warning{background:var(--warning-soft);color:var(--warning);border-color:transparent}
        .badge.dot::before{content:"";width:5px;height:5px;border-radius:50%;background:currentColor}

        /* ── Forms ─────────────────────────────────── */
        .form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px 18px}
        .form-grid .span-2{grid-column:span 2}
        .field{display:flex;flex-direction:column;gap:5px}
        .label{font-size:12px;font-weight:500;color:var(--text-2)}
        .label .req{color:var(--danger)}
        .input,.select,.textarea{background:var(--surface);border:1px solid var(--border-2);
          border-radius:var(--radius-sm);padding:8px 10px;font-size:13px;outline:none;width:100%}
        .input:focus,.select:focus,.textarea:focus{border-color:var(--text);box-shadow:0 0 0 3px var(--surface-2)}
        .textarea{min-height:80px;resize:vertical;font-family:inherit}
        .hint{font-size:11.5px;color:var(--muted)}
        .split{display:grid;grid-template-columns:1fr 320px;gap:16px;align-items:start}
        .col{display:flex;flex-direction:column}
        .gap-12{gap:12px}.gap-16{gap:16px}
        .row{display:flex;align-items:center;gap:8px}
        .divider{height:1px;background:var(--border);margin:12px 0}

        /* ── Misc helpers ───────────────────────────── */
        .mono{font-family:"Geist Mono",ui-monospace,monospace;font-size:12.5px}
        .muted{color:var(--muted)}.text-2{color:var(--text-2)}
        .bold{font-weight:600}.sm{font-size:12px}.xs{font-size:11.5px}
        .num{text-align:right;font-feature-settings:"tnum"}
        .icon{display:inline-block;vertical-align:middle}
        .tabs{display:flex;gap:4px;border-bottom:1px solid var(--border);margin-bottom:18px}
        .tab{padding:8px 14px;border:none;background:none;color:var(--muted);font-size:13px;
          font-weight:500;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px}
        .tab:hover{color:var(--text-2)}.tab.active{color:var(--text);border-bottom-color:var(--text)}

        /* ── Tabulator overrides (FIXED alignment) ──── */
        /*
          ROOT CAUSE of misalignment:
          tabulator_simple.min.css sets .tabulator-cell { display: block }
          Our CSS was setting display:flex;height:44px which fights with
          Tabulator's internal row height system.
          FIX: use rowHeight option in JS + only override colors/fonts, not layout.
        */
        .tabulator{border:none!important;background:transparent;font-size:13px;font-family:inherit}
        .tabulator .tabulator-header{background:var(--surface-2);border-bottom:1px solid var(--border)!important}
        .tabulator .tabulator-header .tabulator-col{
          background:var(--surface-2)!important;border-right:none!important;border-bottom:none!important}
        .tabulator .tabulator-header .tabulator-col .tabulator-col-title{
          font-size:11.5px!important;font-weight:500!important;color:var(--muted)!important;
          text-transform:uppercase;letter-spacing:.04em;padding:10px 14px!important}
        .tabulator-row{border-bottom:1px solid var(--border)!important;background:var(--surface)!important}
        .tabulator-row:last-child{border-bottom:none!important}
        .tabulator-row:hover,.tabulator-row.tabulator-selectable:hover{background:var(--surface-2)!important}
        .tabulator-row .tabulator-cell{
          border-right:none!important;
          padding:0 14px!important;
          /* REMOVED: display:flex;height:var(--row-h) — these break alignment */
          /* Tabulator manages its own cell layout; we only need padding */
          vertical-align:middle;
        }
        .tabulator .tabulator-tableholder{overflow-x:auto}
        .tabulator-footer{background:var(--surface-2)!important;border-top:1px solid var(--border)!important;
          padding:8px 12px!important}
        .tabulator-footer .tabulator-page{
          background:var(--surface)!important;border:1px solid var(--border-2)!important;
          border-radius:var(--radius-sm)!important;padding:4px 10px!important;
          font-size:12px!important;color:var(--text-2)!important;margin:0 2px!important}
        .tabulator-footer .tabulator-page.active{
          background:var(--text)!important;color:var(--surface)!important;border-color:var(--text)!important}
        .tabulator-footer .tabulator-page:disabled{opacity:.4!important}
        .tabulator-placeholder-contents{padding:32px!important;text-align:center!important;
          color:var(--muted)!important;font-size:13px!important}

        /* ── Select2 skin ───────────────────────────── */
        .select2-container--default .select2-selection--single{
          height:36px;border:1px solid var(--border-2);border-radius:var(--radius-sm);
          background:var(--surface);display:flex;align-items:center;padding:0 10px}
        .select2-container--default .select2-selection--single .select2-selection__rendered{
          color:var(--text);font-size:13px;line-height:normal;padding:0}
        .select2-container--default .select2-selection--single .select2-selection__arrow{height:34px;right:6px}
        .select2-container--default .select2-results__option--highlighted{
          background:var(--surface-2)!important;color:var(--text)!important}
        .select2-container--default .select2-results__option--selected{
          background:var(--text)!important;color:var(--surface)!important}
        .select2-dropdown{border:1px solid var(--border-2);border-radius:var(--radius-sm);
          box-shadow:0 4px 12px rgba(0,0,0,.08);font-size:13px}
        .select2-search--dropdown .select2-search__field{
          border:1px solid var(--border-2);border-radius:var(--radius-sm);padding:6px 8px;font-size:13px;outline:none}
        .select2-container{width:100%!important}

        /* ── Toastr overrides ───────────────────────── */
        #toast-container > div{border-radius:var(--radius)!important;font-size:13px!important;
          box-shadow:0 4px 12px rgba(0,0,0,.12)!important}

        /* ── Dashboard ──────────────────────────────── */
        .dash-grid{display:grid;grid-template-columns:2fr 1fr;gap:12px;margin-bottom:12px}

        @@media(max-width:1200px){
          .stat-grid{grid-template-columns:repeat(2,1fr)}
          .dash-grid{grid-template-columns:1fr}
          .split{grid-template-columns:1fr}
        }
        @@media(max-width:800px){.app{grid-template-columns:1fr}.sidebar{display:none}}
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-mark">
                    @if (!string.IsNullOrEmpty(companyLogo))
                    {
                        <img src="@companyLogo" alt="@companyName" />
                    }
                    else
                    {
                        @brandLetter
                    }
                </div>
                <div><div class="brand-name">@companyName</div><div class="brand-sub">Inventory</div></div>
            </div>

            <div class="sidebar-section">Overview</div>
            <a class="nav-item @nav("dashboard")" href="@Url.Action("Index","Dashboard")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="7" height="9" rx="1" /><rect x="14" y="3" width="7" height="5" rx="1" /><rect x="14" y="12" width="7" height="9" rx="1" /><rect x="3" y="16" width="7" height="5" rx="1" /></svg>
                Dashboard
            </a>

            <div class="sidebar-section">Inventory Management</div>
            <a class="nav-item @nav("products")" href="@Url.Action("Index","Product")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /></svg>
                Products
            </a>
            <a class="nav-item @nav("categories")" href="@Url.Action("Index","Category")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 20H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2z" /></svg>
                Categories
            </a>
            <a class="nav-item @nav("units")" href="@Url.Action("Index","Unit")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-4 0v2" /></svg>
                Units
            </a>
            <a class="nav-item @nav("stock")" href="@Url.Action("Index","Stock")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m12 2 8.5 4.5L12 11 3.5 6.5 12 2Z" /><path d="m3.5 12 8.5 4.5 8.5-4.5" /><path d="m3.5 17.5 8.5 4.5 8.5-4.5" /></svg>
                Stock
            </a>

            <div class="sidebar-section">Transactions</div>
            <a class="nav-item @nav("purchases")" href="@Url.Action("Index","Purchase")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2" /><circle cx="7" cy="18" r="2" /><circle cx="17" cy="18" r="2" /></svg>
                Purchases
            </a>
            <a class="nav-item @nav("sales")" href="@Url.Action("Index","Sale")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z" /></svg>
                Sales
            </a>

            <div class="sidebar-section">Directory</div>
            <a class="nav-item @nav("suppliers")" href="@Url.Action("Index","Supplier")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 21h18" /><path d="M5 21V7l8-4v18" /></svg>
                Suppliers
            </a>
            <a class="nav-item @nav("customers")" href="@Url.Action("Index","Customer")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                Customers
            </a>

            <div class="sidebar-section">Finance</div>
            <a class="nav-item @nav("employees")" href="@Url.Action("Index","Employee")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 0 0-4 0v2" /></svg>
                Employees
            </a>
            <a class="nav-item @nav("expenses")" href="@Url.Action("Index","Expense")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 12V22H4V12" /><path d="M22 7H2v5h20V7z" /><path d="M12 22V7" /></svg>
                Expenses
            </a>
            <a class="nav-item @nav("reports")" href="@Url.Action("Index","Report")">
                <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
                Reports
            </a>

            @if (isAdmin)
            {
                <div class="sidebar-section">Administration</div>
                <a class="nav-item @nav("users")" href="@Url.Action("Index","User")">
                    <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                    Users &amp; Roles
                </a>
                <a class="nav-item @nav("company")" href="@Url.Action("Settings","Company")">
                    <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 21h18" /><path d="M5 21V7l8-4v18" /></svg>
                    Company
                </a>
            }

            <div class="sidebar-footer">
                <div class="avatar">@initials</div>
                <div style="min-width:0;flex:1">
                    <div class="user-name">@displayName</div>
                    <div class="user-role">@(isAdmin ? "Admin" : "User")</div>
                </div>
                <form method="post" asp-controller="Auth" asp-action="Logout" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-ghost btn-icon" title="Sign out">
                        <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                    </button>
                </form>
            </div>
        </aside>

        <div class="main">
            <div class="topbar">
                <div>
                    <div class="topbar-title">@ViewData["Title"]</div>
                    @if (ViewData["SubTitle"] != null)
                    {
                        <div class="topbar-sub">@ViewData["SubTitle"]</div>
                    }
                </div>
                <div class="topbar-spacer"></div>
            </div>
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://unpkg.com/tabulator-tables@6.2.1/dist/js/tabulator.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

    <script>
        // ── Toastr config ─────────────────────────────────────────────────────
        toastr.options = {
          positionClass: 'toast-top-right', timeOut: 3500,
          closeButton: true, progressBar: true, newestOnTop: true
        };
        @if (TempData["Success"] != null)
        {
            <text>toastr.success('@Html.Raw(Html.Encode(TempData["Success"]))'); </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>toastr.error('@Html.Raw(Html.Encode(TempData["Error"]))');   </text>
        }
        @if (TempData["Warning"] != null)
        {
            <text>toastr.warning('@Html.Raw(Html.Encode(TempData["Warning"]))'); </text>
        }
        @if (TempData["Info"] != null)
        {
            <text>toastr.info('@Html.Raw(Html.Encode(TempData["Info"]))');    </text>
        }

        // ── CSRF token (used by all fetch POSTs) ──────────────────────────────
        window.__token = document.querySelector('meta[name="__RequestVerificationToken"]')?.content
          ?? '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)?.[1] ?? '';

        async function apiPost(url, body = {}) {
          const resp = await fetch(url, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded',
              'RequestVerificationToken': window.__token
            },
            body: new URLSearchParams(body).toString()
          });
          if (!resp.ok) {
            const txt = await resp.text();
            console.error('apiPost failed', resp.status, txt);
            throw new Error('Request failed: ' + resp.status);
          }
          return resp.json();
        }

        // ── Tabulator shared formatters ───────────────────────────────────────
        function badgeFormatter(cell) {
          const v = (cell.getValue() ?? '').toString().toLowerCase();
          const map = {
            active:    ['success', 'active'],
            inactive:  ['',        'inactive'],
            draft:     ['warning', 'draft'],
            confirmed: ['success', 'confirmed'],
            low:       ['warning', 'low'],
            critical:  ['danger',  'critical'],
            'in stock':['success', 'in stock'],
            'out':     ['danger',  'out of stock'],
          };
          const [cls, label] = map[v] ?? ['', v];
          return `<span class="badge dot ${cls}">${label}</span>`;
        }

        function moneyFormatter(cell) {
          const v = parseFloat(cell.getValue()) || 0;
          return '৳\u00a0' + v.toLocaleString('en-BD', { minimumFractionDigits: 2 });
        }

        // ── Default Tabulator options (FIXED: rowHeight instead of CSS height) ─
        window.tabulatorDefaults = {
          rowHeight: 44,          // ← KEY FIX: controls row height properly
          layout: 'fitColumns',
          pagination: true,
          paginationMode: 'remote',
          paginationSize: 20,
          paginationSizeSelector: [10, 20, 50, 100],
          sortMode: 'remote',
          ajaxResponse: (url, params, resp) => resp,
          placeholder: 'No records found.',
        };
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
