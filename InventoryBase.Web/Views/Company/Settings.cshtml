@model InventoryBase.Core.Entities.CompanySettings
@{ ViewData["Title"] = "Company Settings"; ViewData["NavId"] = "company"; }
@section Styles {
<style>
.co-grid{display:grid;grid-template-columns:1fr 300px;gap:16px;align-items:start}
.co-logo{width:80px;height:80px;border-radius:8px;background:var(--surface-2);
  border:1px solid var(--border);display:grid;place-items:center;
  font-size:28px;font-weight:600;color:var(--text-2);overflow:hidden;flex-shrink:0}
.co-logo img{width:100%;height:100%;object-fit:cover}
.tabs{display:flex;gap:4px;border-bottom:1px solid var(--border);margin-bottom:18px}
.tab{padding:8px 14px;border:none;background:none;color:var(--muted);font-size:13px;
  font-weight:500;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px}
.tab:hover{color:var(--text-2)}.tab.active{color:var(--text);border-bottom-color:var(--text)}
@@media(max-width:1000px){.co-grid{grid-template-columns:1fr}}
</style>
}
<div class="content">
  <div class="page-head">
    <div><h1 class="page-title">Company settings</h1><div class="page-sub">Business profile used on invoices and reports.</div></div>
  </div>

  <div class="tabs">
    <button class="tab active" data-tab="profile">Profile</button>
    <button class="tab" data-tab="fiscal">Fiscal &amp; tax</button>
    <button class="tab" data-tab="docs">Documents</button>
  </div>

  <!-- Profile tab -->
  <div data-pane="profile">
    <form method="post" asp-controller="Company" asp-action="Settings" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <div class="co-grid">
        <div class="card">
          <div class="card-head"><div class="card-title">Business profile</div></div>
          <div class="card-body">
            <div class="row gap-16" style="align-items:flex-start;margin-bottom:18px">
              <div>
                <div class="co-logo" id="logoPreview">
                  @if (!string.IsNullOrEmpty(Model.LogoPath)) { <img src="@Model.LogoPath" id="logoImg"/> }
                  else { <span>@(Model.CompanyName.Length > 0 ? Model.CompanyName[0].ToString().ToUpper() : "A")</span> }
                </div>
                <div class="hint" style="margin-top:6px;text-align:center">Logo</div>
              </div>
              <div class="col gap-12" style="flex:1">
                <div class="field">
                  <label class="label">Company name <span class="req">*</span></label>
                  <input class="input" asp-for="CompanyName" placeholder="e.g. Arcline Gallery"/>
                </div>
                <div class="field">
                  <label class="label">Upload logo</label>
                  <input class="input" name="logoFile" type="file" accept="image/*" id="logoFile"/>
                  <div class="hint">PNG or JPG · shown on invoices</div>
                </div>
              </div>
            </div>
            <div class="form-grid">
              <div class="field">
                <label class="label">Phone</label>
                <input class="input mono" asp-for="Phone" placeholder="+880"/>
              </div>
              <div class="field">
                <label class="label">Email</label>
                <input class="input" asp-for="Email" type="email"/>
              </div>
              <div class="field span-2">
                <label class="label">Address</label>
                <textarea class="textarea" asp-for="Address" placeholder="Full business address"></textarea>
              </div>
            </div>
          </div>
        </div>
        <div class="card" style="align-self:start">
          <div class="card-head"><div class="card-title">Save</div></div>
          <div class="card-body">
            <div class="xs muted" style="margin-bottom:12px">Last updated: @Model.UpdatedAt.ToString("dd MMM yyyy, HH:mm")</div>
            <button type="submit" class="btn btn-primary" style="width:100%">Save settings</button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <!-- Fiscal tab (read-only config display — extend as needed) -->
  <div data-pane="fiscal" style="display:none">
    <div class="co-grid">
      <div class="card">
        <div class="card-head"><div class="card-title">Fiscal &amp; tax</div></div>
        <div class="card-body">
          <div class="form-grid">
            <div class="field">
              <label class="label">Base currency</label>
              <select class="select s2">
                <option selected>BDT — Bangladeshi Taka (৳)</option>
                <option>USD — US Dollar</option>
              </select>
            </div>
            <div class="field">
              <label class="label">Fiscal year starts</label>
              <select class="select s2">
                <option selected>1 July</option>
                <option>1 January</option>
              </select>
            </div>
            <div class="field">
              <label class="label">VAT rate (%)</label>
              <input class="input mono" value="15"/>
              <div class="hint">Applied on sale lines unless overridden per product.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Docs tab -->
  <div data-pane="docs" style="display:none">
    <div class="co-grid">
      <div class="card">
        <div class="card-head"><div class="card-title">Document numbering</div></div>
        <div class="card-body">
          <div class="form-grid">
            <div class="field"><label class="label">Sale invoice prefix</label><input class="input mono" value="INV-"/></div>
            <div class="field"><label class="label">Purchase prefix</label><input class="input mono" value="PO-"/></div>
          </div>
        </div>
      </div>
      <div class="card">
        <div class="card-head"><div class="card-title">Invoice footer note</div></div>
        <div class="card-body">
          <div class="field">
            <textarea class="textarea" style="min-height:120px">Thank you for your purchase. Goods once sold are exchangeable within 7 days against the original receipt.</textarea>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
// Tab switching
$('.tab').on('click', function(){
  const t = $(this).data('tab');
  $('.tab').removeClass('active'); $(this).addClass('active');
  $('[data-pane]').hide(); $('[data-pane="'+t+'"]').show();
  // init Select2 in newly shown pane
  $('[data-pane="'+t+'"] .s2').not('.select2-hidden-accessible').select2({ width: '100%' });
});

// Select2 on visible pane
$('[data-pane="profile"] .s2').select2({ width: '100%' });

// Logo preview
$('#logoFile').on('change', function(){
  const file = this.files[0]; if (!file) return;
  const r = new FileReader();
  r.onload = e => $('#logoPreview').html(`<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover">`);
  r.readAsDataURL(file);
});
</script>
}
