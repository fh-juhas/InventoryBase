@model InventoryBase.Web.ViewModels.LoginViewModel
@{ Layout = null; ViewData["Title"] = "Sign in"; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Sign in · Arcline Gallery</title>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root{--bg:#fafaf8;--surface:#fff;--surface-2:#f5f5f3;--text:#1c1917;--text-2:#57534e;--muted:#a8a29e;--border:#e7e5e4;--border-2:#d6d3d1;--accent:oklch(.55 .10 55);--danger:oklch(.55 .15 25);--radius-sm:4px}
*{box-sizing:border-box}body{margin:0;font-family:"Geist",sans-serif;font-size:14px;color:var(--text);background:var(--bg)}
.page{min-height:100vh;display:grid;grid-template-columns:1fr 1fr}
.left{background:var(--surface-2);display:flex;flex-direction:column;padding:36px;justify-content:space-between;border-right:1px solid var(--border)}
.mark{display:flex;align-items:center;gap:12px}
.brand-mark{width:36px;height:36px;border-radius:6px;background:var(--text);color:var(--surface);display:grid;place-items:center;font-weight:600;font-size:16px}
.brand-name{font-weight:600;font-size:16px}.brand-sub{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.02em}
.quote{max-width:460px;font-size:28px;line-height:1.25;letter-spacing:-.02em;font-weight:500}
.quote .accent{color:var(--accent)}
.meta{font-size:12px;color:var(--muted)}
.right{display:grid;place-items:center;padding:36px}
.card{width:100%;max-width:360px}
.card h1{font-size:22px;font-weight:600;letter-spacing:-.02em;margin:0 0 4px}
.sub{color:var(--muted);margin-bottom:22px;font-size:13.5px}
.field{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
.label{font-size:12px;font-weight:500;color:var(--text-2)}
.input{background:var(--surface);border:1px solid var(--border-2);border-radius:var(--radius-sm);padding:8px 10px;font-size:13px;width:100%;outline:none}
.input:focus{border-color:var(--text);box-shadow:0 0 0 3px var(--surface-2)}
.pw{position:relative}.pw .toggle{position:absolute;right:4px;top:4px;padding:6px 8px;border:none;background:transparent;cursor:pointer;color:var(--muted);font-size:12px}
.check-row{display:flex;align-items:center;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:14px}
.btn{display:block;width:100%;background:var(--text);color:var(--surface);border:none;border-radius:var(--radius-sm);padding:10px;font-size:13px;font-weight:500;cursor:pointer}
.btn:hover{background:var(--text-2)}
.hint{font-size:11.5px;color:var(--muted);text-align:center;margin-top:14px}
.err{background:#fff1f1;color:var(--danger);border-radius:4px;padding:8px 12px;font-size:12.5px;margin-bottom:12px}
@@media(max-width:800px){.page{grid-template-columns:1fr}.left{display:none}}
</style>
</head>
<body>
<div class="page">
  <div class="left">
    <div class="mark">
      <div class="brand-mark">A</div>
      <div><div class="brand-name">Arcline Gallery</div><div class="brand-sub">Inventory Management</div></div>
    </div>
    <div class="quote">A quiet, dependable workspace for everything that passes through <span class="accent">Arcline</span> — every piece, every invoice, every shelf.</div>
    <div class="meta">v1.0 · Chittagong, Bangladesh</div>
  </div>
  <div class="right">
    <div class="card">
      <h1>Sign in</h1>
      <div class="sub">Welcome back. Sign in to your workspace.</div>
      @if (!ViewData.ModelState.IsValid)
      { <div class="err">@string.Join(" ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage))</div> }
      <form method="post" asp-controller="Auth" asp-action="Login">
        @Html.AntiForgeryToken()
        <div class="field"><label class="label">Email</label><input class="input" asp-for="Email" type="email" autocomplete="email"/></div>
        <div class="field">
          <label class="label">Password</label>
          <div class="pw">
            <input class="input" id="pw" asp-for="Password" type="password" style="padding-right:52px" autocomplete="current-password"/>
            <button type="button" class="toggle" id="tgl">Show</button>
          </div>
        </div>
        <div class="check-row"><label><input asp-for="RememberMe" type="checkbox"/> Remember me</label></div>
        <button type="submit" class="btn">Sign in</button>
        <div class="hint">Protected workspace · Contact your administrator for access</div>
      </form>
    </div>
  </div>
</div>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>$('#tgl').on('click',function(){var $p=$('#pw');var t=$p.attr('type')==='password';$p.attr('type',t?'text':'password');$(this).text(t?'Hide':'Show');});</script>
</body>
</html>
