@model InventoryBase.Web.ViewModels.AdminResetPasswordViewModel
@{ ViewData["Title"] = "Reset Password"; ViewData["NavId"] = "users"; var userId = (string)ViewBag.UserId; }
<div class="content">
  <div class="page-head">
    <div>
      <h1 class="page-title">Reset password</h1>
      <div class="page-sub">Resetting password for <strong>@ViewBag.UserName</strong></div>
    </div>
    <div class="page-actions"><a class="btn" href="@Url.Action("Index","User")">Cancel</a></div>
  </div>
  <div style="max-width:440px">
    <div class="card">
      <div class="card-head"><div class="card-title">Set new password</div></div>
      <div class="card-body">
        <form method="post" asp-controller="Auth" asp-action="ResetPassword" asp-route-id="@userId">
          @Html.AntiForgeryToken()
          <div class="field">
            <label class="label">New password <span class="req">*</span></label>
            <input class="input" asp-for="NewPassword" type="password" autocomplete="new-password" autofocus/>
            <div class="hint">Minimum 6 characters.</div>
            <span asp-validation-for="NewPassword" class="hint" style="color:var(--danger)"></span>
          </div>
          <div class="field">
            <label class="label">Confirm password <span class="req">*</span></label>
            <input class="input" asp-for="ConfirmPassword" type="password" autocomplete="new-password"/>
            <span asp-validation-for="ConfirmPassword" class="hint" style="color:var(--danger)"></span>
          </div>
          <div style="display:flex;gap:8px;margin-top:16px">
            <button type="submit" class="btn btn-primary">Reset password</button>
            <a class="btn" href="@Url.Action("Index","User")">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
