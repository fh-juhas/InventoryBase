@{ Layout = null; }
<!DOCTYPE html><html lang="en"><head><meta charset="utf-8"/><title>Setup Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Geist:wght@@400;500;600&display=swap" rel="stylesheet"/>
<style>*{box-sizing:border-box}body{margin:0;font-family:"Geist",sans-serif;font-size:14px;background:#fafaf8;display:grid;place-items:center;min-height:100vh}
.c{background:#fff;border:1px solid #e7e5e4;border-radius:6px;padding:28px;width:380px}
h1{font-size:18px;font-weight:600;margin:0 0 4px}.sub{color:#a8a29e;font-size:12.5px;margin-bottom:20px}
.f{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
.l{font-size:12px;font-weight:500;color:#57534e}
.i{background:#fff;border:1px solid #d6d3d1;border-radius:4px;padding:8px 10px;font-size:13px;width:100%;outline:none}
.i:focus{border-color:#1c1917;box-shadow:0 0 0 3px #f5f5f3}
.btn{display:block;width:100%;background:#1c1917;color:#fff;border:none;border-radius:4px;padding:10px;font-size:13px;font-weight:500;cursor:pointer;margin-top:4px}
.note{font-size:11.5px;color:#a8a29e;margin-top:14px;padding:10px;background:#f5f5f3;border-radius:4px}</style>
</head><body>
<div class="c">
  <h1>Create First Admin</h1>
  <div class="sub">Temporary setup. Remove this after first use.</div>
  <form method="post" asp-controller="Auth" asp-action="Register">
    @Html.AntiForgeryToken()
    <div class="f"><label class="l">Full name</label><input class="i" name="fullName" required/></div>
    <div class="f"><label class="l">Email</label><input class="i" name="email" type="email" required/></div>
    <div class="f"><label class="l">Password</label><input class="i" name="password" type="password" minlength="6" required/></div>
    <button type="submit" class="btn">Create Admin Account</button>
  </form>
  <div class="note">⚠ Disable <code>AuthController.Register</code> after creating the first admin.</div>
</div>
</body></html>
