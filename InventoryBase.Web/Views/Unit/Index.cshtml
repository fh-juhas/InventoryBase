@{
    ViewData["Title"] = "Units";
    ViewData["NavId"] = "units";
    var isAdmin = User.IsInRole("Admin");
}
<div class="content">
  <div class="page-head">
    <div>
      <h1 class="page-title">Units</h1>
      <div class="page-sub">Measurement units assigned to products (e.g. pc, kg, m, set).</div>
    </div>
    <div class="page-actions">
      <a class="btn btn-primary" href="@Url.Action("Create","Unit")">+ New unit</a>
    </div>
  </div>

  <div class="table-wrap">
    <!-- Toolbar -->
    <div class="table-toolbar">
      <div class="search-box">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="search" placeholder="Search units…"/>
      </div>
      <select class="select" id="filterStatus" style="width:150px">
        <option value="">All statuses</option>
        <option value="active">Active</option>
        <option value="inactive">Inactive</option>
      </select>
      <div class="spacer"></div>
      <span class="xs muted" id="rowCount"></span>
    </div>
    <div id="unitTable"></div>
  </div>
</div>

@section Scripts {
<script>
const isAdmin = @isAdmin.ToString().ToLower();

let filters = { search: '', status: '' };

const table = new Tabulator('#unitTable', {
  ajaxURL: '/Unit/Data',
  ajaxParams: () => ({ ...filters }),
  ajaxResponse: (url, params, resp) => resp,  // pass through — already correct shape
  pagination: true,
  paginationMode: 'remote',
  paginationSize: 20,
  paginationSizeSelector: [10, 20, 50, 100],
  sortMode: 'remote',
  filterMode: 'remote',
  layout: 'fitColumns',
  responsiveLayout: 'collapse',
  placeholder: 'No units found.',
  columns: [
    { title: 'Name',   field: 'name',   widthGrow: 3,
      formatter: cell => `<span class="bold">${cell.getValue()}</span>` },
    { title: 'Status', field: 'status', width: 130, formatter: badgeFormatter },
    { title: '',       field: 'hash',   width: isAdmin ? 160 : 90,
      hozAlign: 'right', headerSort: false,
      formatter: cell => {
        const h = cell.getValue();
        let btns = `<a href="/Unit/Edit/${h}" class="btn btn-ghost btn-sm">Edit</a>`;
        if (isAdmin) btns += ` <button onclick="delUnit('${h}')" class="btn btn-ghost btn-sm btn-danger">Delete</button>`;
        return `<div class="row" style="justify-content:flex-end">${btns}</div>`;
      }
    }
  ]
});

table.on('dataProcessed', () => {
  const count = table.getDataCount('active');
  document.getElementById('rowCount').textContent = count + ' rows';
});

// filters
let debounce;
document.getElementById('search').addEventListener('input', e => {
  clearTimeout(debounce);
  debounce = setTimeout(() => { filters.search = e.target.value; table.setPage(1); }, 350);
});
document.getElementById('filterStatus').addEventListener('change', e => {
  filters.status = e.target.value; table.setPage(1);
});

async function delUnit(hash) {
  if (!confirm('Delete this unit?')) return;
  const data = await apiPost('/Unit/Delete/' + hash);
  if (data.success) { toastr.success('Unit deleted.'); table.replaceData(); }
  else toastr.error(data.message || 'Delete failed.');
}
</script>
}
