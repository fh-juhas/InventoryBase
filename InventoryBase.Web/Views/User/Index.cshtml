@{
    ViewData["Title"] = "Users & Roles"; ViewData["NavId"] = "users";
}
@section Styles {
<style>
.role-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:20px}
.role-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px}
.role-card h3{margin:0 0 4px;font-size:13px;font-weight:600}
.role-card .count{font-size:24px;font-weight:600;letter-spacing:-.02em;margin:6px 0 2px}
</style>
}
<div class="content">
  <div class="page-head">
    <div><h1 class="page-title">Users &amp; Roles</h1><div class="page-sub">People with access to this workspace.</div></div>
    <div class="page-actions">
      <a class="btn" href="@Url.Action("ChangePassword","Auth")">🔑 Change my password</a>
      <a class="btn btn-primary" href="@Url.Action("Create","User")">+ Invite user</a>
    </div>
  </div>

  <div class="role-grid">
    <div class="role-card"><h3>Admin</h3><div class="count" id="cntAdmin">—</div><div class="xs muted">Full access</div></div>
    <div class="role-card"><h3>User</h3><div class="count"  id="cntUser">—</div><div class="xs muted">Standard access</div></div>
  </div>

  <div class="table-wrap">
    <div class="table-toolbar">
      <div class="search-box">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="search" placeholder="Search name or email…"/>
      </div>
      <select class="select s2-role" id="filterRole" style="width:140px">
        <option value="">All roles</option>
        <option value="admin">Admin</option>
        <option value="user">User</option>
      </select>
      <select class="select" id="filterStatus" style="width:150px">
        <option value="">All statuses</option>
        <option value="active">Active</option>
        <option value="inactive">Inactive</option>
      </select>
      <div class="spacer"></div>
      <span class="xs muted" id="rowCount"></span>
    </div>
    <div id="userTable"></div>
  </div>
</div>

@section Scripts {
<script>
let filters = { search: '', role: '', status: '' };

fetch('/User/RoleCounts').then(r => r.json()).then(d => {
  document.getElementById('cntAdmin').textContent = d.admins;
  document.getElementById('cntUser').textContent  = d.users;
});

const table = new Tabulator('#userTable', {
  ...window.tabulatorDefaults,
  ajaxURL: '/User/Data',
  ajaxParams: () => ({ ...filters }),
  columns: [
    { title: 'Name',   field: 'fullName', widthGrow: 2,
      formatter: c => {
        const n = c.getValue() || '';
        const initials = n.split(' ').filter(Boolean).slice(0,2).map(w=>w[0].toUpperCase()).join('');
        return `<div style="display:flex;align-items:center;gap:8px">
          <div style="width:24px;height:24px;border-radius:50%;background:var(--accent-soft);
            color:var(--accent);display:inline-grid;place-items:center;
            font-size:10px;font-weight:600;flex-shrink:0">${initials}</div>
          <span class="bold">${n}</span></div>`;
      }
    },
    { title: 'Email',  field: 'email',    widthGrow: 2,
      formatter: c => `<span class="muted">${c.getValue()}</span>` },
    { title: 'Role',   field: 'role',     width: 100 },
    { title: 'Status', field: 'status',   width: 110, formatter: badgeFormatter },
    { title: '',       field: 'hash',     width: 230,
      hozAlign: 'right', headerSort: false,
      formatter: cell => {
        const row    = cell.getRow().getData();
        const hash   = cell.getValue();
        const uid    = row.identityId;
        let btns = `<a href="/Auth/ResetPassword/${uid}" class="btn btn-ghost btn-sm">Reset pwd</a>`;
        if (row.isActive) {
          btns += ` <button onclick="deactivate('${hash}')" class="btn btn-ghost btn-sm btn-danger">Deactivate</button>`;
        }
        return `<div class="row" style="justify-content:flex-end">${btns}</div>`;
      }
    }
  ]
});

table.on('dataProcessed', () => {
  document.getElementById('rowCount').textContent = table.getDataCount('active') + ' rows';
});

let deb;
document.getElementById('search').addEventListener('input', e => {
  clearTimeout(deb); deb = setTimeout(() => { filters.search = e.target.value; table.setPage(1); }, 350);
});
$('#filterRole').on('change', e => { filters.role = e.target.value || ''; table.setPage(1); });
$('#filterRole').select2({ minimumResultsForSearch: Infinity, width: '140px' });
document.getElementById('filterStatus').addEventListener('change', e => {
  filters.status = e.target.value; table.setPage(1);
});

async function deactivate(hash) {
  if (!confirm('Deactivate this user?')) return;
  try {
    const d = await apiPost('/User/Deactivate/' + hash);
    if (d.success) {
      toastr.success('User deactivated.');
      table.replaceData();
      fetch('/User/RoleCounts').then(r=>r.json()).then(d => {
        document.getElementById('cntAdmin').textContent = d.admins;
        document.getElementById('cntUser').textContent  = d.users;
      });
    } else toastr.error(d.message || 'Failed.');
  } catch(e) { toastr.error('Request failed.'); }
}
</script>
}
