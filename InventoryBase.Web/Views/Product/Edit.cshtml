@model InventoryBase.Core.Entities.Product
@{
    ViewData["Title"] = "Edit product"; ViewData["NavId"] = "products";
    var hashId     = (string)ViewBag.HashId;
    var categories = (IEnumerable<InventoryBase.Core.Entities.Category>)ViewBag.Categories;
    var units      = (IEnumerable<InventoryBase.Core.Entities.Unit>)ViewBag.Units;
}
<div class="content">
  <div class="page-head">
    <div><h1 class="page-title">Edit product</h1><div class="page-sub">@Model.Name · <span class="mono">@Model.SKU</span></div></div>
    <div class="page-actions"><a class="btn" href="@Url.Action("Index","Product")">Cancel</a></div>
  </div>
  <form method="post" asp-controller="Product" asp-action="Edit" asp-route-id="@hashId">
    @Html.AntiForgeryToken()
    <div class="split">
      <div class="col gap-16">
        <div class="card">
          <div class="card-head"><div class="card-title">Basic information</div></div>
          <div class="card-body">
            <div class="form-grid">
              <div class="field span-2">
                <label class="label">Product name <span class="req">*</span></label>
                <input class="input" asp-for="Name"/>
                <span asp-validation-for="Name" class="hint" style="color:var(--danger)"></span>
              </div>
              <div class="field">
                <label class="label">SKU <span class="req">*</span></label>
                <input class="input mono" asp-for="SKU"/>
                <span asp-validation-for="SKU" class="hint" style="color:var(--danger)"></span>
              </div>
              <div class="field">
                <label class="label">Unit <span class="req">*</span></label>
                <select class="select s2-unit" asp-for="UnitID">
                  <option value="">— Select unit —</option>
                  @foreach (var u in units) { <option value="@u.Id" selected="@(Model.UnitID==u.Id)">@u.Name</option> }
                </select>
                <span asp-validation-for="UnitID" class="hint" style="color:var(--danger)"></span>
              </div>
              <div class="field span-2">
                <label class="label">Category <span class="req">*</span></label>
                <select class="select s2-cat" asp-for="CategoryId">
                  <option value="">— Select category —</option>
                  @foreach (var c in categories) { <option value="@c.Id" selected="@(Model.CategoryId==c.Id)">@c.Name</option> }
                </select>
                <span asp-validation-for="CategoryId" class="hint" style="color:var(--danger)"></span>
              </div>
              <div class="field span-2">
                <label class="label">Description</label>
                <textarea class="textarea" asp-for="Description"></textarea>
              </div>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-head"><div class="card-title">Pricing</div></div>
          <div class="card-body">
            <div class="form-grid">
              <div class="field">
                <label class="label">Cost price (৳) <span class="req">*</span></label>
                <input class="input mono" asp-for="CostPrice"/>
                <span asp-validation-for="CostPrice" class="hint" style="color:var(--danger)"></span>
              </div>
              <div class="field">
                <label class="label">Sale price (৳) <span class="req">*</span></label>
                <input class="input mono" asp-for="SalePrice"/>
                <span asp-validation-for="SalePrice" class="hint" style="color:var(--danger)"></span>
              </div>
              <div class="field span-2">
                <label class="label">Low-stock alert level</label>
                <input class="input mono" asp-for="ReorderLevel" type="number" min="0" step="0.001"/>
                <div class="hint">Stock at or below this quantity is flagged as low. Default 10.</div>
                <span asp-validation-for="ReorderLevel" class="hint" style="color:var(--danger)"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col gap-12">
        <div class="card">
          <div class="card-head"><div class="card-title">Status</div></div>
          <div class="card-body">
            <label class="row" style="gap:8px;cursor:pointer">
              <input asp-for="IsActive" type="checkbox"/> <span>Active</span>
            </label>
            <div class="divider"></div>
            <div class="xs muted">Created: @Model.CreatedAt.ToString("dd MMM yyyy")</div>
          </div>
        </div>
        <div style="display:flex;gap:8px">
          <button type="submit" class="btn btn-primary">Save changes</button>
          <a class="btn" href="@Url.Action("Index","Product")">Cancel</a>
        </div>
      </div>
    </div>
  </form>
</div>
@section Scripts {
<script>
$('.s2-cat').select2({ placeholder: '— Select category —', allowClear: true, width: '100%' });
$('.s2-unit').select2({ placeholder: '— Select unit —', allowClear: true, width: '100%' });
</script>
}
