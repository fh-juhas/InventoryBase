@{
    ViewData["Title"] = "Expense Templates"; ViewData["NavId"] = "expenses";
}
<div class="content">
  <div class="page-head">
    <div><h1 class="page-title">Expense templates</h1><div class="page-sub">Define recurring expense types used to auto-generate monthly expenses.</div></div>
    <div class="page-actions"><a class="btn" href="@Url.Action("Index","Expense")">← Back to expenses</a></div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 320px;gap:16px;align-items:start">
    <div class="table-wrap">
      <div class="table-toolbar">
        <div class="search-box">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input id="search" placeholder="Search templates…"/>
        </div>
      </div>
      <div id="tplTable"></div>
    </div>
    <div class="card" style="align-self:start">
      <div class="card-head"><div class="card-title">Add template</div></div>
      <div class="card-body">
        <form method="post" asp-controller="Expense" asp-action="CreateTemplate">
          @Html.AntiForgeryToken()
          <div class="field">
            <label class="label">Name <span class="req">*</span></label>
            <input class="input" name="Name" placeholder="e.g. Rent, Electricity" required/>
          </div>
          <div class="field">
            <label class="label">Description</label>
            <input class="input" name="Description" placeholder="Optional"/>
          </div>
          <div class="field">
            <label class="label">Default amount (৳)</label>
            <input class="input mono" name="DefaultAmount" type="number" step="0.01" value="0"/>
          </div>
          <button type="submit" class="btn btn-primary" style="margin-top:8px;width:100%">Add template</button>
        </form>
      </div>
    </div>
  </div>
</div>
@section Scripts {
<script>
let filters = { search: '' };
const table = new Tabulator('#tplTable', {
  ajaxURL: '/Expense/TemplateData',
  ajaxParams: () => ({ ...filters }),
  ajaxResponse: (url, params, resp) => resp,
  pagination: true, paginationMode: 'remote',
  paginationSize: 20, layout: 'fitColumns',
  placeholder: 'No templates yet.',
  columns: [
    { title: 'Name',           field: 'name',          widthGrow: 2,
      formatter: c => `<span class="bold">${c.getValue()}</span>` },
    { title: 'Description',    field: 'description',   widthGrow: 2,
      formatter: c => `<span class="muted">${c.getValue()}</span>` },
    { title: 'Default (৳)',    field: 'defaultAmount',  width: 120,
      hozAlign: 'right', formatter: moneyFormatter },
    { title: '',               field: 'hash',           width: 90,
      hozAlign: 'right', headerSort: false,
      formatter: cell => {
        const h = cell.getValue();
        return `<button onclick="delTpl('${h}')" class="btn btn-ghost btn-sm btn-danger">Delete</button>`;
      }
    }
  ]
});

let deb;
document.getElementById('search').addEventListener('input', e => {
  clearTimeout(deb); deb = setTimeout(() => { filters.search = e.target.value; table.setPage(1); }, 350);
});

async function delTpl(hash) {
  if (!confirm('Delete this template?')) return;
  const d = await apiPost('/Expense/DeleteTemplate/' + hash);
  if (d.success) { toastr.success('Template deleted.'); table.replaceData(); }
  else toastr.error('Delete failed.');
}
</script>
}
