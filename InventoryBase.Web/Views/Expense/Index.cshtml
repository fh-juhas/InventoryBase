@{
    ViewData["Title"] = "Expenses"; ViewData["NavId"] = "expenses";
    int  month   = (int?)ViewBag.Month ?? DateTime.Now.Month;
    int  year    = (int?)ViewBag.Year  ?? DateTime.Now.Year;
    var  months  = System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.MonthNames.Take(12).ToArray();
    var  isAdmin = User.IsInRole("Admin");
}
<div class="content">
  <div class="page-head">
    <div>
      <h1 class="page-title">Expenses</h1>
      <div class="page-sub">Monthly tracking — <strong>@months[month-1] @year</strong></div>
    </div>
    <div class="page-actions">
      <!-- Period picker (GET form — not apiPost) -->
      <form method="get" asp-controller="Expense" asp-action="Index" style="display:flex;gap:8px">
        <select class="select s2-month" name="month" style="width:130px">
          @for (int m = 1; m <= 12; m++) {
            <option value="@m" selected="@(m==month)">@months[m-1]</option>
          }
        </select>
        <select class="select s2-year" name="year" style="width:90px">
          @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 3; y--) {
            <option value="@y" selected="@(y==year)">@y</option>
          }
        </select>
        <button type="submit" class="btn">Go</button>
      </form>
      <button id="btnGenerate"    class="btn" style="display:none">Generate from templates</button>
      <button id="btnAddExpense"  class="btn" style="display:none">+ Add expense</button>
      <button id="btnConfirm"     class="btn btn-primary" style="display:none">Confirm &amp; lock</button>
    </div>
  </div>

  <div class="table-wrap">
    <div class="table-toolbar">
      <div class="search-box">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="search" placeholder="Search category…"/>
      </div>
      <select class="select" id="filterStatus" style="width:160px">
        <option value="">All statuses</option>
        <option value="draft">Draft</option>
        <option value="confirmed">Confirmed</option>
      </select>
      <div class="spacer"></div>
      <div class="bold" style="font-size:13px">Total: <span id="totalAmount" class="mono">৳ 0.00</span></div>
    </div>
    <div id="expTable"></div>
  </div>

  @if (isAdmin) {
    <div style="margin-top:16px">
      <a class="btn" href="@Url.Action("Templates","Expense")">Manage expense templates</a>
    </div>
  }
</div>

<dialog id="addExpenseModal" style="border:1px solid var(--border);border-radius:var(--radius);padding:0;background:var(--surface);color:var(--text);min-width:360px;max-width:440px;width:100%">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 16px;border-bottom:1px solid var(--border)">
    <span style="font-weight:600;font-size:14px">Add expense</span>
    <button type="button" id="closeAddModal" class="btn btn-ghost btn-icon btn-sm" style="line-height:1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <form id="addExpenseForm" style="padding:16px;display:flex;flex-direction:column;gap:12px">
    <div class="field">
      <label class="label">Category <span class="req" style="color:var(--danger)">*</span></label>
      <input class="input" id="addCategory" placeholder="e.g. Rent, Utilities…" required autocomplete="off">
    </div>
    <div class="field">
      <label class="label">Description</label>
      <input class="input" id="addDescription" placeholder="Optional details" autocomplete="off">
    </div>
    <div class="field">
      <label class="label">Amount (৳) <span class="req" style="color:var(--danger)">*</span></label>
      <input class="input mono" id="addAmount" type="number" step="0.01" min="0" placeholder="0.00" required>
    </div>
    <div style="display:flex;justify-content:flex-end;gap:8px;padding-top:4px">
      <button type="button" id="cancelAddExpense" class="btn">Cancel</button>
      <button type="submit" class="btn btn-primary">Add expense</button>
    </div>
  </form>
</dialog>

@section Scripts {
<script>
const MONTH   = @month;
const YEAR    = @year;
let filters   = { month: MONTH, year: YEAR, search: '', status: '' };

// ── Load summary ─────────────────────────────────────────────────────
async function loadSummary() {
  try {
    const s = await fetch(`/Expense/MonthSummary?month=${MONTH}&year=${YEAR}`).then(r => r.json());
    document.getElementById('totalAmount').textContent =
      '৳ ' + parseFloat(s.total || 0).toLocaleString('en-BD', { minimumFractionDigits: 2 });
    document.getElementById('btnGenerate').style.display   = s.hasDraft ? 'none' : '';
    document.getElementById('btnAddExpense').style.display  = s.hasDraft ? ''     : 'none';
    document.getElementById('btnConfirm').style.display     = s.hasDraft ? ''     : 'none';
  } catch(e) { console.error('loadSummary failed', e); }
}
loadSummary();

// ── Tabulator ────────────────────────────────────────────────────────
const table = new Tabulator('#expTable', {
  ...window.tabulatorDefaults,
  ajaxURL: '/Expense/Data',
  ajaxParams: () => ({ ...filters }),
  columns: [
    { title: 'Category',    field: 'category',    widthGrow: 2,
      formatter: c => `<span class="bold">${c.getValue()}</span>` },
    { title: 'Description', field: 'description', widthGrow: 2,
      formatter: c => `<span class="muted">${c.getValue()}</span>` },
    { title: 'Amount (৳)',  field: 'amount',       width: 180,
      hozAlign: 'right',
      formatter: (cell) => {
        const row = cell.getRow().getData();
        if (row.isDraft) {
          return `<input type="number" class="input mono"
            style="width:140px;text-align:right;padding:4px 8px;height:30px"
            value="${parseFloat(cell.getValue()).toFixed(2)}"
            step="0.01"
            data-hash="${row.hash}"
            onchange="updateAmount(this)"
            onclick="event.stopPropagation()"/>`;
        }
        return moneyFormatter(cell);
      }
    },
    { title: 'Status', field: 'status', width: 130, formatter: badgeFormatter },
    { title: '', field: 'hash', width: 52, hozAlign: 'center', headerSort: false,
      formatter: (cell) => {
        if (!cell.getRow().getData().isDraft) return '';
        const h = cell.getValue();
        return `<button class="btn btn-ghost btn-icon btn-danger btn-sm" title="Remove"
          onclick="removeExpense('${h}',event)">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
            <path d="M10 11v6"/><path d="M14 11v6"/>
          </svg></button>`;
      }
    }
  ]
});

// ── Filters ──────────────────────────────────────────────────────────
let deb;
document.getElementById('search').addEventListener('input', e => {
  clearTimeout(deb); deb = setTimeout(() => { filters.search = e.target.value; table.setPage(1); }, 350);
});
document.getElementById('filterStatus').addEventListener('change', e => {
  filters.status = e.target.value; table.setPage(1);
});

// ── Generate — FIX: was returning redirect, now returns JSON ─────────
document.getElementById('btnGenerate').addEventListener('click', async () => {
  const btn = document.getElementById('btnGenerate');
  btn.disabled = true; btn.textContent = 'Generating…';
  try {
    const d = await apiPost('/Expense/Generate', { month: MONTH, year: YEAR });
    if (d.success) {
      toastr.success(d.message || 'Expenses generated.');
      await table.replaceData();
      await loadSummary();
    } else {
      toastr.error(d.message || 'Generation failed.');
    }
  } catch(e) {
    toastr.error('Request failed. Check console.');
    console.error(e);
  } finally {
    btn.disabled = false; btn.textContent = 'Generate from templates';
  }
});

// ── Confirm — same fix ────────────────────────────────────────────────
document.getElementById('btnConfirm').addEventListener('click', async () => {
  if (!confirm(`Lock all expenses for ${MONTH}/${YEAR}?\nThis cannot be undone.`)) return;
  const btn = document.getElementById('btnConfirm');
  btn.disabled = true; btn.textContent = 'Locking…';
  try {
    const d = await apiPost('/Expense/Confirm', { month: MONTH, year: YEAR });
    if (d.success) {
      toastr.success(d.message || 'Expenses confirmed.');
      await table.replaceData();
      await loadSummary();
    } else {
      toastr.error(d.message || 'Failed.');
    }
  } catch(e) {
    toastr.error('Request failed.'); console.error(e);
  } finally {
    btn.disabled = false; btn.textContent = 'Confirm & lock';
  }
});

// ── Inline amount update ──────────────────────────────────────────────
async function updateAmount(el) {
  const val  = parseFloat(el.value);
  const hash = el.dataset.hash;
  if (isNaN(val) || val < 0) return;
  try {
    const d = await apiPost('/Expense/UpdateAmount', { id: hash, amount: val });
    if (d.success) {
      el.style.borderColor = 'var(--success)';
      setTimeout(() => el.style.borderColor = '', 1200);
      loadSummary();
    } else { toastr.error('Failed to update amount.'); }
  } catch(e) { toastr.error('Request failed.'); }
}

// ── Remove a single draft expense ────────────────────────────────────
async function removeExpense(hash, event) {
  event.stopPropagation();
  if (!confirm('Remove this expense item from this month?')) return;
  try {
    const d = await apiPost('/Expense/DeleteExpense', { id: hash });
    if (d.success) {
      toastr.success('Expense removed.');
      await table.replaceData();
      await loadSummary();
    } else { toastr.error(d.message || 'Failed to remove.'); }
  } catch(e) { toastr.error('Request failed.'); console.error(e); }
}

// ── Add expense modal ─────────────────────────────────────────────────
const addModal = document.getElementById('addExpenseModal');
document.getElementById('btnAddExpense').addEventListener('click', () => addModal.showModal());
document.getElementById('closeAddModal').addEventListener('click', () => addModal.close());
document.getElementById('cancelAddExpense').addEventListener('click', () => addModal.close());
addModal.addEventListener('click', e => { if (e.target === addModal) addModal.close(); });

document.getElementById('addExpenseForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const category    = document.getElementById('addCategory').value.trim();
  const description = document.getElementById('addDescription').value.trim();
  const amount      = parseFloat(document.getElementById('addAmount').value);
  if (!category || isNaN(amount) || amount < 0) return;
  try {
    const d = await apiPost('/Expense/AddExpense',
      { month: MONTH, year: YEAR, category, description, amount });
    if (d.success) {
      toastr.success('Expense added.');
      addModal.close();
      document.getElementById('addExpenseForm').reset();
      await table.replaceData();
      await loadSummary();
    } else { toastr.error(d.message || 'Failed to add expense.'); }
  } catch(e) { toastr.error('Request failed.'); console.error(e); }
});

// ── Select2 on period pickers ─────────────────────────────────────────
$('.s2-month').select2({ minimumResultsForSearch: Infinity, width: '130px' });
$('.s2-year').select2({ minimumResultsForSearch: Infinity, width: '90px' });
</script>
}
