@model InventoryBase.Core.Entities.Employee
@{ ViewData["Title"] = "Add employee"; ViewData["NavId"] = "employees"; }
<div class="content">
  <div class="page-head">
    <div><h1 class="page-title">Add employee</h1><div class="page-sub">Fields marked <span style="color:var(--danger)">*</span> required.</div></div>
    <div class="page-actions"><a class="btn" href="@Url.Action("Index","Employee")">Cancel</a></div>
  </div>
  <div style="max-width:600px">
    <div class="card">
      <div class="card-head"><div class="card-title">Employee details</div></div>
      <div class="card-body">
        <form method="post" asp-controller="Employee" asp-action="Create">
          @Html.AntiForgeryToken()
          <div class="form-grid">
            <div class="field span-2">
              <label class="label">Full name <span class="req">*</span></label>
              <input class="input" asp-for="Name" placeholder="e.g. Nasrin Akter" autofocus/>
              <span asp-validation-for="Name" class="hint" style="color:var(--danger)"></span>
            </div>
            <div class="field">
              <label class="label">Role / designation</label>
              <input class="input" asp-for="Role" placeholder="e.g. Sales Executive"/>
            </div>
            <div class="field">
              <label class="label">Salary (৳) <span class="req">*</span></label>
              <input class="input mono" asp-for="Salary" placeholder="0.00"/>
              <span asp-validation-for="Salary" class="hint" style="color:var(--danger)"></span>
            </div>
            <div class="field">
              <label class="label">Phone</label>
              <input class="input mono" asp-for="Phone" placeholder="+880"/>
            </div>
            <div class="field">
              <label class="label">Email</label>
              <input class="input" asp-for="Email" type="email"/>
            </div>
            <div class="field span-2">
              <label class="label">Join date <span class="req">*</span></label>
              <input class="input" asp-for="JoinDate" type="date"/>
              <span asp-validation-for="JoinDate" class="hint" style="color:var(--danger)"></span>
            </div>
          </div>
          <div style="display:flex;gap:8px;margin-top:16px">
            <button type="submit" class="btn btn-primary">Save employee</button>
            <a class="btn" href="@Url.Action("Index","Employee")">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
